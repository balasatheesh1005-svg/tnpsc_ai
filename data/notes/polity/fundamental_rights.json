{
  "subject": "Polity",
  "topic": "Fundamental Rights",
  "language": "bilingual",
  "ui_type": "polity",
  "content": {

    "definition": {
      "en": "Fundamental Rights are basic rights guaranteed by the Constitution to all citizens to ensure liberty, equality and justice.",
      "ta": "அடிப்படை உரிமைகள் என்பது அரசியலமைப்பால் குடிமக்களுக்கு வழங்கப்பட்ட முக்கிய உரிமைகள் ஆகும். இவை சுதந்திரம், சமத்துவம் மற்றும் நீதி உறுதி செய்கின்றன."
    },

    "general_features": [
      {
        "title": "Nature of Fundamental Rights",
        "points": {
          "en": [
            "Guaranteed by Part III (Articles 12–35)",
            "Justiciable in courts",
            "Protect against State actions",
            "Not absolute (reasonable restrictions)",
            "Can be suspended during Emergency (except Articles 20 & 21)"
          ],
          "ta": [
            "பகுதி III (12–35 கட்டுரைகள்)",
            "நீதிமன்றத்தில் அமல்படுத்தலாம்",
            "அரசின் செயல்களிலிருந்து பாதுகாப்பு",
            "முழுமையானவை அல்ல",
            "அவசரநிலையில் இடைநிறுத்தலாம் (20 & 21 தவிர)"
          ]
        }
      }
    ],

    "right_to_equality": [
      {
        "title": "Article 14 – Equality before Law",
        "points": {
          "en": [
            "Equality before law",
            "Equal protection of laws",
            "No discrimination by State"
          ],
          "ta": [
            "சட்டத்தின் முன் சமத்துவம்",
            "சமமான பாதுகாப்பு",
            "பாகுபாடு இல்லை"
          ]
        }
      },
      {
        "title": "Article 15 – Prohibition of Discrimination",
        "points": {
          "en": [
            "No discrimination on religion, race, caste, sex",
            "Special provisions allowed for women & children",
            "Reservation permitted"
          ],
          "ta": [
            "மதம், ஜாதி, பாலினம் அடிப்படையில் பாகுபாடு இல்லை",
            "பெண்கள் மற்றும் குழந்தைகளுக்கு சலுகை",
            "ஒதுக்கீடு அனுமதி"
          ]
        }
      },
      {
        "title": "Article 16 – Equality of Opportunity",
        "points": {
          "en": [
            "Equal opportunity in public employment",
            "Reservation for backward classes",
            "No discrimination in jobs"
          ],
          "ta": [
            "அரசு வேலை வாய்ப்பில் சம வாய்ப்பு",
            "பின்தங்கியோருக்கு ஒதுக்கீடு",
            "பாகுபாடு இல்லை"
          ]
        }
      },
      {
        "title": "Article 17 – Abolition of Untouchability",
        "points": {
          "en": [
            "Untouchability abolished",
            "Punishable offence",
            "Civil Rights Act enforced"
          ],
          "ta": [
            "தொட்டுக்கூடாத நிலை நீக்கம்",
            "குற்றமாக கருதப்படுகிறது",
            "சிவில் உரிமைகள் சட்டம்"
          ]
        }
      },
      {
        "title": "Article 18 – Abolition of Titles",
        "points": {
          "en": [
            "No titles except military/academic",
            "No titles like Raja, Rai Bahadur",
            "Promotes equality"
          ],
          "ta": [
            "பட்டங்கள் இல்லை (இராணுவம் தவிர)",
            "ராஜா போன்ற பட்டங்கள் இல்லை",
            "சமத்துவம் உறுதி"
          ]
        }
      }
    ],

    "right_to_freedom": [
      {
