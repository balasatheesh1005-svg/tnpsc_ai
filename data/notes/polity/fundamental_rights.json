          "ta": [
            "6–14 வயது இலவச கல்வி",
            "86வது திருத்தம்",
            "கடமை தொடர்பு"
          ]
        }
      },
      {
        "title": "Article 22 – Protection against Arrest",
        "points": {
          "en": [
            "Right to be informed",
            "Right to lawyer",
            "Produced before magistrate",
            "Preventive detention allowed"
          ],
          "ta": [
            "காரணம் அறிவிக்க வேண்டும்",
            "வழக்கறிஞர் உரிமை",
            "நீதிபதி முன் ஆஜர்",
            "தடுப்பு கைது அனுமதி"
          ]
        }
      }
    ],

    "right_against_exploitation": [
      {
        "title": "Article 23 – Prohibition of Human Trafficking",
        "points": {
          "en": [
            "Ban on human trafficking",
            "Forced labour prohibited",
            "Punishable offence"
          ],
          "ta": [
            "மனித கடத்தல் தடை",
