{
  "subject": "Polity",
  "topic": "Preamble of Indian Constitution",
  "language": "bilingual",
  "ui_type": "polity",
  "content": {

    "definition": {
      "en": "The Preamble is the introductory statement of the Constitution that contains its philosophy, objectives and ideals.",
      "ta": "முன்னுரை என்பது அரசியலமைப்பின் அறிமுகப் பகுதி ஆகும். இது அதன் இலக்குகள், தத்துவம் மற்றும் அடிப்படை மதிப்புகளை விளக்குகிறது."
    },

    "keywords": [
      {
        "title": "Sovereign",
        "points": {
          "en": [
            "India is free from external control",
            "No foreign authority can control India",
            "Independent in internal and external affairs"
          ],
          "ta": [
            "இந்தியா வெளிநாட்டு கட்டுப்பாட்டிலிருந்து சுதந்திரமானது",
            "வேறு நாடு கட்டுப்படுத்த முடியாது",
            "உள் மற்றும் வெளி விஷயங்களில் சுயாட்சி"
          ]
        }
      },

      {
        "title": "Socialist",
        "points": {
          "en": [
            "Added by 42nd Amendment (1976)",
            "Promotes economic equality",
            "Reduces income inequality",
            "Welfare state concept"
          ],
          "ta": [
            "42வது திருத்தம் (1976) மூலம் சேர்க்கப்பட்டது",
            "பொருளாதார சமத்துவம்",
            "வருமான வேறுபாடு குறைப்பு",
            "நலநிலை அரசு"
          ]
        }
      },

      {
        "title": "Secular",
        "points": {
          "en": [
            "Added by 42nd Amendment",
            "State has no official religion",
            "Equal respect to all religions",
            "Freedom of religion"
          ],
          "ta": [
            "42வது திருத்தம் மூலம் சேர்க்கப்பட்டது",
            "அரசுக்கு மதம் இல்லை",
            "அனைத்து மதங்களுக்கும் சம மதிப்பு",
            "மத சுதந்திரம்"
          ]
        }
      },

      {
        "title": "Democratic",
        "points": {
          "en": [
            "People elect their government",
            "Universal adult franchise",
            "Political equality",
            "Rule of majority"
          ],
          "ta": [
            "மக்கள் அரசு தேர்வு செய்கின்றனர்",
            "பொது வாக்குரிமை",
            "அரசியல் சமத்துவம்",
            "பெரும்பான்மை ஆட்சி"
          ]
        }
      },

      {
        "title": "Republic",
        "points": {
          "en": [
            "Head of State is elected",
            "No hereditary monarchy",
            "President is elected",
            "Public office open to all"
          ],
          "ta": [
            "தலைவர் தேர்ந்தெடுக்கப்படுகிறார்",
            "மரபுரிமை அரசாட்சி இல்லை",
            "குடியரசுத் தலைவர் தேர்வு",
            "எவரும் பதவி வகிக்கலாம்"
          ]
        }
      }
    ],

    "objectives": [
      {
        "title": "Justice",
        "points": {
          "en": [
            "Social justice",
            "Economic justice",
            "Political justice"
          ],
          "ta": [
            "சமூக நீதி",
            "பொருளாதார நீதி",
            "அரசியல் நீதி"
          ]
        }
      },

      {
        "title": "Liberty",
        "points": {
          "en": [
            "Freedom of thought",
            "Freedom of expression",
            "Freedom of belief and faith"
          ],
          "ta": [
            "சிந்தனை சுதந்திரம்",
            "வாக்குரிமை சுதந்திரம்",
            "நம்பிக்கை சுதந்திரம்"
          ]
        }
      },

      {
        "title": "Equality",
        "points": {
          "en": [
            "Equality before law",
            "Equal opportunity",
            "No discrimination"
          ],
          "ta": [
            "சட்டத்தின் முன் சமத்துவம்",
            "சம வாய்ப்பு",
            "பாகுபாடு இல்லை"
          ]
        }
      },

      {
        "title": "Fraternity",
        "points": {
          "en": [
            "Unity and integrity",
            "Brotherhood among people",
            "Dignity of individual"
          ],
          "ta": [
            "ஒற்றுமை மற்றும் முழுமை",
            "சகோதரத்துவம்",
            "மனித மரியாதை"
          ]
        }
      }
    ],

    "importance": {
      "en": [
        "Reflects philosophy of Constitution",
        "Guides interpretation of laws",
        "Based on Objective Resolution",
        "Not enforceable in court"
      ],
      "ta": [
        "அரசியலமைப்பின் தத்துவத்தை காட்டுகிறது",
        "சட்ட விளக்கத்திற்கு உதவும்",
        "நோக்கு தீர்மானத்தின் அடிப்படை",
        "நீதிமன்றத்தில் அமல்படுத்த முடியாது"
      ]
    }

  }
}