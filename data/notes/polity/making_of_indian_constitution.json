  "content": {

    "definition": {
      "en": "The Indian Constitution was framed by the Constituent Assembly between 1946 and 1949.",
      "ta": "இந்திய அரசியல் அமைப்பு 1946 முதல் 1949 வரை அரசியல் அமைப்புச் சபையால் உருவாக்கப்பட்டது."
    },

    "acts": [

      {
        "title": "Cabinet Mission Plan, 1946",
        "points": {
          "en": [
            "Proposed formation of Constituent Assembly",
            "Members indirectly elected",
            "Total members: 389"
          ],
          "ta": [
            "அரசியல் அமைப்புச் சபை அமைப்பை பரிந்துரைத்தது",
            "உறுப்பினர்கள் மறைமுகமாக தேர்ந்தெடுக்கப்பட்டனர்",
            "மொத்த உறுப்பினர்கள்: 389"
          ]
        }
      },

      {
        "title": "Constituent Assembly Formation",
        "points": {
          "en": [
            "First meeting: December 9, 1946",
            "Temporary President: Dr. Sachchidananda Sinha",
            "Permanent President: Dr. Rajendra Prasad"
          ],
          "ta": [
            "முதல் கூட்டம்: டிசம்பர் 9, 1946",
            "தற்காலிக தலைவர்: டாக்டர் சச்சிதானந்த சின்ஹா",
            "நிலையான தலைவர்: டாக்டர் ராஜேந்திர பிரசாத்"
          ]
        }
      },

      {
        "title": "Drafting Committee (1947)",
        "points": {
          "en": [
            "Formed on August 29, 1947",
            "Chairman: Dr. B. R. Ambedkar",
            "Prepared draft constitution"
          ],
          "ta": [
            "ஆகஸ்ட் 29, 1947 அன்று அமைக்கப்பட்டது",
            "தலைவர்: டாக்டர் பி.ஆர். அம்பேத்கர்",
            "வரைவு அரசியல் அமைப்பு தயாரித்தது"
          ]
        }
      },

      {
        "title": "Adoption of Constitution",
        "points": {
          "en": [
            "Adopted on November 26, 1949",
            "Came into force on January 26, 1950",
            "January 26 celebrated as Republic Day"
          ],
          "ta": [
            "நவம்பர் 26, 1949 அன்று ஏற்றுக்கொள்ளப்பட்டது",
            "ஜனவரி 26, 1950 முதல் அமலுக்கு வந்தது",
            "ஜனவரி 26 குடியரசு தினமாக கொண்டாடப்படுகிறது"
          ]
        }
      },

      {
        "title": "Time Taken",
        "points": {
          "en": [
            "2 years, 11 months, 18 days",
            "Total sittings: 11 sessions"
          ],
          "ta": [
            "2 ஆண்டுகள், 11 மாதங்கள், 18 நாட்கள்",
            "மொத்த கூட்டங்கள்: 11"
          ]
        }
      },

      {
        "title": "Sources of Constitution",
        "points": {
