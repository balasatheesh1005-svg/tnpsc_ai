{
  "subject": "Polity",
  "topic": "Features of Indian Constitution",
  "language": "bilingual",
  "ui_type": "polity",
  "content": {

    "definition": {
      "en": "The Indian Constitution has unique features combining rigidity, flexibility and influences from various countries.",
      "ta": "இந்திய அரசியலமைப்பு பல நாடுகளின் தாக்கங்களுடன் கடினத்தன்மையும் நெகிழ்வுத்தன்மையும் இணைந்த தனித்துவ அம்சங்களைக் கொண்டது."
    },

    "acts": [

      {
        "title": "Lengthiest Constitution",
        "points": {
          "en": [
            "World's lengthiest written constitution",
            "Contains detailed provisions",
            "Originally 395 Articles and 8 Schedules",
            "Now expanded with amendments"
          ],
          "ta": [
            "உலகிலேயே நீளமான எழுதப்பட்ட அரசியலமைப்பு",
            "விவரமான விதிகள் அடங்கியவை",
            "முதலில் 395 கட்டுரைகள் மற்றும் 8 அட்டவணைகள்",
            "திருத்தங்களால் விரிவடைந்தது"
          ]
        }
      },

      {
        "title": "Drawn from Various Sources",
        "points": {
          "en": [
            "Borrowed features from many countries",
            "UK – Parliamentary system",
            "USA – Fundamental Rights",
            "Ireland – Directive Principles"
          ],
          "ta": [
            "பல நாடுகளிலிருந்து அம்சங்கள் எடுத்தது",
            "இங்கிலாந்து – பாராளுமன்ற முறை",
            "அமெரிக்கா – அடிப்படை உரிமைகள்",
            "அயர்லாந்து – வழிகாட்டும் கோட்பாடுகள்"
          ]
        }
      },

      {
        "title": "Blend of Rigidity and Flexibility",
        "points": {
          "en": [
            "Some provisions are rigid",
            "Some are flexible",
            "Amendment process varies",
            "Not fully rigid like USA"
          ],
          "ta": [
            "சில விதிகள் கடினமானவை",
            "சில விதிகள் நெகிழ்வானவை",
            "திருத்த முறைகள் மாறுபடும்",
            "முழுமையாக கடினமானது அல்ல"
          ]
        }
      },

      {
        "title": "Federal System with Unitary Bias",
        "points": {
          "en": [
            "Division of powers between Centre and States",
            "Strong central government",
            "Unitary features during emergency",
            "Single Constitution"
          ],
          "ta": [
            "மத்திய மற்றும் மாநில அதிகாரப் பிரிவு",
            "வலுவான மத்திய அரசு",
            "அவசரநிலையில் ஒருங்கிணைந்த அமைப்பு",
            "ஒற்றை அரசியலமைப்பு"
          ]
        }
      },

      {
        "title": "Parliamentary Form of Government",
        "points": {
          "en": [
            "Executive responsible to legislature",
            "President is nominal head",
            "Prime Minister is real head",
            "Based on UK model"
          ],
          "ta": [
            "நிர்வாகம் சட்டமன்றத்திற்கு பொறுப்பு",
            "குடியரசுத் தலைவர் பெயரளவு தலைவர்",
            "முதல்வர்/பிரதமர் உண்மையான தலைவர்",
            "இங்கிலாந்து முறை"
          ]
        }
      },

      {
        "title": "Fundamental Rights",
        "points": {
          "en": [
            "Guarantees basic rights",
            "Ensures equality and freedom",
            "Justiciable in courts",
            "Inspired by USA"
          ],
          "ta": [
            "அடிப்படை உரிமைகள் வழங்குகிறது",
            "சமத்துவம் மற்றும் சுதந்திரம் உறுதி",
            "நீதிமன்றத்தில் நடைமுறைப்படுத்தலாம்",
            "அமெரிக்கா தாக்கம்"
          ]
        }
      },

      {
        "title": "Directive Principles of State Policy",
        "points": {
          "en": [
            "Guidelines for government",
            "Not enforceable by courts",
            "Promotes welfare state",
            "Inspired by Ireland"
          ],
          "ta": [
            "அரசுக்கு வழிகாட்டுதல்கள்",
            "நீதிமன்றத்தில் அமல்படுத்த முடியாது",
            "நலநிலை அரசு உருவாக்கம்",
            "அயர்லாந்து தாக்கம்"
          ]
        }
      },

      {
        "title": "Fundamental Duties",
        "points": {
          "en": [
            "Added by 42nd Amendment",
            "Citizens' responsibilities",
            "Promotes discipline and unity",
            "Inspired by USSR"
          ],
          "ta": [
            "42வது திருத்தம் மூலம் சேர்க்கப்பட்டது",
            "குடிமக்களின் கடமைகள்",
            "ஒற்றுமை மற்றும் ஒழுக்கம்",
            "சோவியத் தாக்கம்"
          ]
        }
      },

      {
        "title": "Independent Judiciary",
        "points": {
          "en": [
            "Supreme Court at apex",
            "Judicial review power",
            "Protects Constitution",
            "Ensures rule of law"
          ],
          "ta": [
            "உச்சநீதிமன்றம் உச்ச நிலையில்",
            "நீதித்துறை மறுபரிசீலனை அதிகாரம்",
            "அரசியலமைப்பை பாதுகாக்கிறது",
            "சட்டத்தின் ஆட்சி உறுதி"
          ]
        }
      },

      {
        "title": "Single Citizenship",
        "points": {
          "en": [
            "Only one citizenship",
            "No separate state citizenship",
            "Promotes unity",
            "Unlike USA"
          ],
          "ta": [
            "ஒற்றை குடியுரிமை",
            "மாநில குடியுரிமை இல்லை",
            "ஒற்றுமை வளர்ச்சி",
            "அமெரிக்காவை விட வேறுபாடு"
          ]
        }
      }

    ]
  }
}